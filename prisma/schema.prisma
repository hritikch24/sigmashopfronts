generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  utmSource String?  @map("utm_source")
  utmMedium String?  @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  device    String?
  browser   String?
  country   String?
  ip        String?
  sessionId String   @map("session_id")
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([sessionId])
  @@map("page_views")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  location  String
  service   String
  message   String?
  source    String?
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model CallClick {
  id          String   @id @default(cuid())
  action      String   @default("call_click")
  phone       String
  page        String
  referrer    String?
  utmSource   String?  @map("utm_source")
  utmMedium   String?  @map("utm_medium")
  utmCampaign String?  @map("utm_campaign")
  device      String?
  browser     String?
  country     String?
  ip          String?
  sessionId   String   @map("session_id")
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
  @@index([sessionId])
  @@map("call_clicks")
}

model Customer {
  id          String    @id @default(cuid())
  name        String
  phone       String
  email       String?
  location    String
  service     String
  jobType     String    @default("installation") @map("job_type")
  status      String    @default("enquiry")
  price       Float?
  notes       String?
  source      String?
  completedAt DateTime? @map("completed_at")
  lastContact DateTime? @map("last_contact")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  documents   Document[]

  @@index([status])
  @@index([createdAt])
  @@index([phone])
  @@map("customers")
}

model Document {
  id              String    @id @default(cuid())
  type            String    // "quote" | "invoice"
  number          String    @unique
  customerId      String?   @map("customer_id")
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName    String    @map("customer_name")
  customerEmail   String?   @map("customer_email")
  customerPhone   String?   @map("customer_phone")
  customerAddress String?   @map("customer_address")
  lineItems       Json      @map("line_items")
  subtotal        Float
  vatRate         Float     @default(0) @map("vat_rate")
  vatAmount       Float     @default(0) @map("vat_amount")
  total           Float
  notes           String?
  meta            Json?
  depositPercent  Float?    @map("deposit_percent")
  validUntil      DateTime? @map("valid_until")
  dueDate         DateTime? @map("due_date")
  status          String    @default("draft")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([customerId])
  @@index([createdAt])
  @@map("documents")
}
